@using MudBlazor
@using MudBlazor.Components
@using GlazerOps.Components
@using GlazerOps.Models
@using GlazerOps.Services
@using DomainJob = GlazerOps.Models.Domain.Job
@typeparam TItem
@using Microsoft.AspNetCore.Components;
@inherits ComponentBase

<MudPaper Class="cda">
    @if (!string.IsNullOrWhiteSpace(Title) || HasTableSupport || OnRefresh.HasDelegate || ShowSearchBar || ShowSortOptions)
    {
        <div class="cda-header">
            <div class="d-flex justify-content-between align-items-center">
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <h3>@Title</h3>
                }
                else
                {
                    <span></span>
                }
                @if (HasTableSupport || OnRefresh.HasDelegate)
                {
                    <div class="d-flex align-items-center gap-2">
                        @if (OnRefresh.HasDelegate)
                        {
                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    @onclick="TriggerRefreshAsync"
                                    disabled="@(IsLoading || IsRefreshing)">
                                @(IsRefreshing ? RefreshingText : RefreshButtonText)
                            </button>
                        }
                        @if (HasTableSupport)
                        {
                            <div class="btn-group" role="group">
                                <button type="button" class="btn @(!_showTableView ? "btn-primary" : "btn-outline-primary")" @onclick="() => _showTableView = false">
                                    Card View
                                </button>
                                <button type="button" class="btn @(_showTableView ? "btn-primary" : "btn-outline-primary")" @onclick="() => _showTableView = true">
                                    Table View
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (ShowSearchBar || ShowSortOptions)
            {
                <div class="cda-tools">
                    @if (ShowSearchBar)
                    {
                        <input type="search"
                               class="form-control cda-search-input"
                               placeholder="@SearchPlaceholder"
                               @bind="_searchText"
                               @bind:event="oninput" />
                    }
                    @if (ShowSortOptions)
                    {
                        <select class="form-select cda-sort-select" @bind="_sortOption">
                            <option value="@SortNone">Default</option>
                            <option value="@SortAscending">A - Z</option>
                            <option value="@SortDescending">Z - A</option>
                        </select>
                    }
                </div>
            }
        </div>
    }

    <div class="cda-content">
        @if (IsLoading)
        {
            <div class="loading-container">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <p>@LoadingText</p>
            </div>
        }
        else if (_showTableView && HasTableSupport)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        @TableHeader
                    </thead>
                    <tbody>
                        @if (!TableItems.Any())
                        {
                            <tr>
                                <td colspan="@TableColumnCount" class="text-center">@EmptyText</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in TableItems)
                            {
                                @TableRow!(item)
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (HasJobIds)
        {
            @if (!DisplayedJobs.Any())
            {
                <div class="empty-state">
                    <p>@EmptyText</p>
                </div>
            }
            else
            {
                <div class="cards-grid">
                    @foreach (var job in DisplayedJobs)
                    {
                        <JobCard Job="job" />
                    }
                </div>
            }
        }
        else if (DisplayedItems == null || !DisplayedItems.Any() || ChildContent is null)
        {
            <div class="empty-state">
                <p>@EmptyText</p>
            </div>
        }
        else
        {
            <div class="cards-grid">
                @foreach (var item in DisplayedItems)
                {
                    @ChildContent(item)
                }
            </div>
        }
    </div>
</MudPaper>

<style>
    .cda {
        border-radius: 8px;
        border: 2px solid maroon;
        backdrop-filter: blur(4px);
        min-height: 300px;
        width: 100%;
        margin: 16px;
    }

    .cda-header {
        padding: 16px;
        border-bottom: 3px solid rgba(0, 0, 0, 0.08);
    }

    .cda-header h3 {
        margin: 0;
        font-size: 1.5em;
        color: darkred;
    }

    .cda-tools {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 12px;
    }

    .cda-search-input {
        max-width: 320px;
        min-width: 220px;
    }

    .cda-sort-select {
        max-width: 180px;
    }

    .cda-content {
        padding: 16px;
    }

    .cards-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 200px;
        gap: 16px;
    }

    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 200px;
        color: #999;
    }

    .table-container {
        width: 100%;
        overflow-x: auto;
    }
</style>

@code {
    [Inject]
    public LocalJobsStore LocalJobsStore { get; set; } = null!;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string CardFilter { get; set; } = string.Empty;

    [Parameter]
    public IEnumerable<long>? JobIds { get; set; }

    [Parameter]
    public IEnumerable<TItem>? Items { get; set; }

    [Parameter]
    public RenderFragment<TItem>? ChildContent { get; set; }

    [Parameter]
    public Func<TItem, string, bool>? FilterFunc { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public bool IsRefreshing { get; set; }

    [Parameter]
    public string LoadingText { get; set; } = "Loading...";

    [Parameter]
    public string EmptyText { get; set; } = "No items to display";

    [Parameter]
    public string RefreshButtonText { get; set; } = "Refresh";

    [Parameter]
    public string RefreshingText { get; set; } = "Refreshing...";

    [Parameter]
    public EventCallback OnRefresh { get; set; }

    [Parameter]
    public RenderFragment? TableHeader { get; set; }

    [Parameter]
    public RenderFragment<TItem>? TableRow { get; set; }

    [Parameter]
    public int TableColumnCount { get; set; } = 1;

    [Parameter]
    public bool ShowSearchBar { get; set; } = true;

    [Parameter]
    public bool ShowSortOptions { get; set; } = true;

    [Parameter]
    public string SearchPlaceholder { get; set; } = "Search...";

    private const string SortNone = "none";
    private const string SortAscending = "asc";
    private const string SortDescending = "desc";

    private bool _showTableView = false;
    private string _searchText = string.Empty;
    private string _sortOption = SortNone;

    private bool HasTableSupport => TableHeader is not null || TableRow is not null;

    private IEnumerable<TItem> TableItems =>
        HasJobIds
            ? DisplayedJobs.Cast<TItem>()
            : (DisplayedItems ?? Enumerable.Empty<TItem>());

    private bool HasJobIds => JobIds is not null;

    private IReadOnlyList<DomainJob> MatchedJobs =>
        !HasJobIds
            ? Array.Empty<DomainJob>()
            : JobIds!
                .Distinct()
                .Join(
                    LocalJobsStore.Jobs,
                    id => id,
                    job => job.Id,
                    (id, job) => job)
                .ToList();

    private IEnumerable<DomainJob> DisplayedJobs =>
        ApplyJobSort(ApplyJobSearch(ApplyJobSearch(MatchedJobs, CardFilter), _searchText));

    private IEnumerable<TItem>? EffectiveItems =>
        Items ?? (typeof(TItem) == typeof(DomainJob) ? LocalJobsStore.Jobs.Cast<TItem>() : null);

    private IEnumerable<TItem>? DisplayedItems =>
        EffectiveItems == null
            ? null
            : ApplyItemSort(ApplyItemSearch(ApplyItemSearch(EffectiveItems, CardFilter), _searchText));

    private IEnumerable<DomainJob> ApplyJobSearch(IEnumerable<DomainJob> jobs, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            return jobs;
        }

        var term = searchTerm.Trim();
        return jobs.Where(job =>
            job.JobName.Contains(term, StringComparison.OrdinalIgnoreCase)
            || job.PONumber?.ToString().Contains(term, StringComparison.OrdinalIgnoreCase) == true
            || job.Site?.SiteName?.Contains(term, StringComparison.OrdinalIgnoreCase) == true);
    }

    private IEnumerable<DomainJob> ApplyJobSort(IEnumerable<DomainJob> jobs) =>
        _sortOption switch
        {
            SortAscending => jobs.OrderBy(job => job.JobName).ThenBy(job => job.Id),
            SortDescending => jobs.OrderByDescending(job => job.JobName).ThenByDescending(job => job.Id),
            _ => jobs
        };

    private IEnumerable<TItem> ApplyItemSearch(IEnumerable<TItem> items, string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            return items;
        }

        if (FilterFunc is not null)
        {
            return items.Where(item => FilterFunc(item, searchTerm));
        }

        var term = searchTerm.Trim();
        return items.Where(item => item?.ToString()?.Contains(term, StringComparison.OrdinalIgnoreCase) == true);
    }

    private IEnumerable<TItem> ApplyItemSort(IEnumerable<TItem> items) =>
        _sortOption switch
        {
            SortAscending => items.OrderBy(item => item?.ToString()),
            SortDescending => items.OrderByDescending(item => item?.ToString()),
            _ => items
        };

    private Task TriggerRefreshAsync() =>
        OnRefresh.HasDelegate ? OnRefresh.InvokeAsync() : Task.CompletedTask;
}
