@using MudBlazor
@using MudBlazor.Components
@using GlazerOps.Components
@using GlazerOps.Models
@using GlazerOps.Services
@using DomainJob = GlazerOps.Models.Domain.Job
@typeparam TItem
@using Microsoft.AspNetCore.Components;
@inherits ComponentBase

<MudPaper Class="cda">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <div class="cda-header">
            <h3>@Title</h3>
        </div>
    }

    <div class="cda-content">
        @if (IsLoading)
        {
            <div class="loading-container">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <p>@LoadingText</p>
            </div>
        }
        else if (HasJobIds)
        {
            @if (!MatchedJobs.Any())
            {
                <div class="empty-state">
                    <p>@EmptyText</p>
                </div>
            }
            else
            {
                <div class="cards-grid">
                    @foreach (var job in MatchedJobs)
                    {
                        <JobCard Job="job" />
                    }
                </div>
            }
        }
        else if (FilteredItems == null || !FilteredItems.Any() || ChildContent is null)
        {
            <div class="empty-state">
                <p>@EmptyText</p>
            </div>
        }
        else
        {
            <div class="cards-grid">
                @foreach (var item in FilteredItems)
                {
                    @ChildContent(item)
                }
            </div>
        }
    </div>
</MudPaper>

<style>
    .cda {
        border-radius: 8px;
        border: 2px solid maroon;
        backdrop-filter: blur(4px);
        min-height: 300px;
        width: 100%;
        margin: 16px;
    }

    .cda-header {
        padding: 16px;
        border-bottom: 3px solid rgba(0, 0, 0, 0.08);
    }

    .cda-header h3 {
        margin: 0;
        font-size: 1.5em;
        color: darkred;
    }

    .cda-content {
        padding: 16px;
    }

    .cards-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 200px;
        gap: 16px;
    }

    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 200px;
        color: #999;
    }
</style>

@code {
    [Inject]
    public LocalJobsStore LocalJobsStore { get; set; } = null!;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string CardFilter { get; set; } = string.Empty;

    [Parameter]
    public IEnumerable<long>? JobIds { get; set; }

    [Parameter]
    public IEnumerable<TItem>? Items { get; set; }

    [Parameter]
    public RenderFragment<TItem>? ChildContent { get; set; }

    [Parameter]
    public Func<TItem, string, bool>? FilterFunc { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public string LoadingText { get; set; } = "Loading...";

    [Parameter]
    public string EmptyText { get; set; } = "No items to display";

    private bool HasJobIds => JobIds is not null;

    private IReadOnlyList<DomainJob> MatchedJobs =>
        !HasJobIds
            ? Array.Empty<DomainJob>()
            : JobIds!
                .Distinct()
                .Join(
                    LocalJobsStore.Jobs,
                    id => id,
                    job => job.Id,
                    (id, job) => job)
                .ToList();

    private IEnumerable<TItem>? EffectiveItems =>
        Items ?? (typeof(TItem) == typeof(DomainJob) ? LocalJobsStore.Jobs.Cast<TItem>() : null);

    private IEnumerable<TItem>? FilteredItems =>
        EffectiveItems == null ? null :
        string.IsNullOrWhiteSpace(CardFilter) ? EffectiveItems :
        FilterFunc != null ? EffectiveItems.Where(item => FilterFunc(item, CardFilter)) :
        EffectiveItems;
}
