@using MudBlazor
@using GlazerOps.Models.Domain
@inject NavigationManager Navigation
@using GlazerOps.Services


<MudPaper Class="jc" Elevation="3">
    <div class="jc_leftside">
        <h2 class="jc_header">@Job?.JobName</h2>
        <p class="jc_PONumber"> @Job?.PONumber</p>
        <p class="jc_contacts"><strong>Contacts:</strong> @Job?.GetCurrentContact()?.Name</p>
    </div>
    <div class="jc_rightside">
        <p class="jc_sitename"><strong>@Job?.Site?.SiteName</strong></p>
        @if (!string.IsNullOrWhiteSpace(Job?.Site?.Address1))
        {
            <p class="job-card__location">@Job.Site.Address1</p>
        }

        @if (!string.IsNullOrWhiteSpace(Job?.Site?.Address2))
        {
            <p class="job-card__location">@Job.Site.Address2</p>
        }
    </div>
</MudPaper>

<style>
    .jc {
        display: flex;
        width: 100%;
        margin-bottom: 10px;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        width: 100%;
        padding: 12px;
        box-sizing: border-box;
        border-radius: 8px;
        border: 1px solid #000;
        background-color: #ddd;
    }

    .jc_leftside {
        flex: 1 1 65%;
        min-width: 40%;
        text-align: left;
    }

    .jc_rightside {
        flex: 1 1 35%;
        min-width: 20%;
        text-align: right;
    }

    .jc_header {
        margin: 0 0 8px 0;
        font-size: 1.25em;
        color: #c00;
        overflow-wrap: anywhere;
    }

    .jc_PONumber,
    .jc_contacts,
    .jc_sitename,
    .jc_location {
        margin: 4px 0;
        color: #111;
        overflow-wrap: anywhere;
    }

    @@media (max-width: 768px) {
        .job-card {
            flex-direction: column;
        }

        .job-card__right {
            text-align: left;
        }
    }
</style>

@code {
    [Parameter]
    public Job? Job { get; set; }

    public string jName     =>
        string.IsNullOrWhiteSpace(Job?.JobName) ? "—" : Job!.JobName!;
    private string jPO => Job?.PONumber is null ? "—" : Job!.PONumber!.ToString();
    private string jContacts => string.IsNullOrWhiteSpace(Job?.GetCurrentContact()?.Name) ? "—" : Job!.GetCurrentContact()!.Name!;

    private string sName => string.IsNullOrWhiteSpace(Job?.Site?.SiteName) ? "—" : Job!.Site!.SiteName!;
    private string AddressLine1 => Job?.Site?.Address1 ?? string.Empty;
    private string AddressLine2 => Job?.Site?.Address2 ?? string.Empty;
    
}
