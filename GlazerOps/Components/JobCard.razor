@using GlazerOps.Models
@using MudBlazor
@using DomainJob = GlazerOps.Models.Domain.Job
@using JobCardModel = GlazerOps.Models.JobCardModel

<MudPaper Class="jc" Elevation="3">
    <div class="jc_leftside">
        <h2 class="jc_header">@_DisplayJobName</h2>
        <p class="jc_PONumber">@DisplayPONumber</p>
        <p class="jc_contacts"><strong>Contacts:</strong> @DisplayContacts</p>
    </div>
    <div class="jc_rightside">
        <p class="jc_sitename"><strong>@DisplaySiteName</strong></p>
        @if (!string.IsNullOrWhiteSpace(DisplayAddress1))
        {
            <p class="jc_location">@DisplayAddress1</p>
        }

        @if (!string.IsNullOrWhiteSpace(DisplayAddress2))
        {
            <p class="jc_location">@DisplayAddress2</p>
        }
    </div>
</MudPaper>

<style>
    .jc {
        display: flex;
        width: 100%;
        margin-bottom: 10px;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        width: 100%;
        padding: 12px;
        box-sizing: border-box;
        border-radius: 8px;
        border: 1px solid #000;
        background-color: #ddd;
    }

    .jc_leftside {
        flex: 1 1 65%;
        min-width: 40%;
        text-align: left;
    }

    .jc_rightside {
        flex: 1 1 35%;
        min-width: 20%;
        text-align: right;
    }

    .jc_header {
        display: flex;
        margin: 0 0 8px 0;
        font-size: 1.25em;
        color: #c00;
        overflow-wrap: anywhere;
    }

    .jc_PONumber,
    .jc_contacts,
    .jc_sitename,
    .jc_location {
        margin: 4px 0;
        color: #111;
        overflow-wrap: anywhere;
    }

    @@media (max-width: 768px) {
        .jc {
            flex-direction: column;
        }

        .jc_rightside {
            text-align: end;
        }
    }
</style>

@code {
    [Parameter]
    public DomainJob? Job { get; set; }

    [Parameter]
    public JobCardModel? Card { get; set; }

    private string _DisplayJobName =>
        !string.IsNullOrWhiteSpace(Card?.job_name) ? Card.job_name :
        !string.IsNullOrWhiteSpace(Job?.JobName) ? Job.JobName : "—";

    private string DisplayPONumber =>
        Card?.po_number?.ToString()
        ?? Job?.PONumber?.ToString()
        ?? "—";

    private string DisplayContacts =>
        !string.IsNullOrWhiteSpace(Card?.primary_contacts) ? Card.primary_contacts :
        !string.IsNullOrWhiteSpace(Card?.all_contacts) ? Card.all_contacts :
        !string.IsNullOrWhiteSpace(Job?.GetCurrentContact()?.Name) ? Job.GetCurrentContact()!.Name : "—";

    private string DisplaySiteName =>
        !string.IsNullOrWhiteSpace(Card?.site_name) ? Card.site_name :
        !string.IsNullOrWhiteSpace(Job?.Site?.SiteName) ? Job.Site.SiteName : "—";

    private string DisplayAddress1 => Card?.address_1 ?? Job?.Site?.Address1 ?? string.Empty;

    private string DisplayAddress2 => Card?.address_2 ?? Job?.Site?.Address2 ?? string.Empty;
}
