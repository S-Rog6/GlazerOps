@using GlazerOps.Models
@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@using DomainJob = GlazerOps.Models.Domain.Job
@using JobCardModel = GlazerOps.Models.JobCardModel
@using GlazerOps.Services

@inject LocalJobsStore LocalJobsStore

<MudPaper Class="@CardCssClass"
          Elevation="3"
          role="@CardRole"
          tabindex="@CardTabIndex"
          @onclick="OnCardClick"
          @onkeydown="HandleCardKeyDown">

    <MudStack Spacing="2">
        <div class="jc_summary">
            <div class="jc_leftside">
                <h2 class="jc_header">@DisplayJobName</h2>
                <p class="jc_poNumber">@DisplayPONumber</p>
                <p class="jc_contacts"><strong>Contacts:</strong> @DisplayContacts</p>
            </div>

            <div class="jc_rightside">
                <p class="jc_sitename"><strong>@DisplaySiteName</strong></p>

                @if (!string.IsNullOrWhiteSpace(DisplayAddress1))
                {
                    <p class="jc_location">@DisplayAddress1</p>
                }

                @if (!string.IsNullOrWhiteSpace(DisplayAddress2))
                {
                    <p class="jc_location">@DisplayAddress2</p>
                }
            </div>
        </div>

       
            <MudDivider />

            <MudCollapse Expanded="_isDrawerOpen">
               @if (HasDrawerContent)
        {  
            <div class="jc_drawer">
                    @if (!string.IsNullOrWhiteSpace(DisplayDrawerContacts))
                    {
                        <p class="jc_drawer_row">
                            <strong>Additional Contacts:</strong> @DisplayDrawerContacts
                        </p>
                    }

                    @if (!string.IsNullOrWhiteSpace(DisplayPinnedNotes))
                    {
                        <p class="jc_drawer_row">
                            <strong>Pinned Notes:</strong> @DisplayPinnedNotes
                        </p>
                    }

                    @if (!string.IsNullOrWhiteSpace(DisplayScheduleDates))
                    {
                        <p class="jc_drawer_row">
                            <strong>Schedule Dates:</strong> @DisplayScheduleDates
                        </p>
                    }
                </div>
            }
            </MudCollapse>
       
    </MudStack>
</MudPaper>

<style>
    .jc {
        width: 100%;
        margin-bottom: 10px;
        padding: 12px;
        box-sizing: border-box;
        border-radius: 8px;
        border: 1px solid #000;
        background-color: #ddd;
    }

    .jc_clickable {
        cursor: pointer;
    }

    .jc_summary {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
    }

    .jc_leftside {
        flex: 1 1 65%;
        min-width: 40%;
        text-align: left;
    }

    .jc_rightside {
        flex: 1 1 35%;
        min-width: 20%;
        text-align: right;
    }

    .jc_header {
        margin: 0 0 8px 0;
        font-size: 1.25em;
        color: #c00;
        overflow-wrap: anywhere;
    }

    .jc_poNumber,
    .jc_contacts,
    .jc_sitename,
    .jc_location {
        margin: 4px 0;
        color: #111;
        overflow-wrap: anywhere;
    }

    .jc_drawer {
        margin: 10px 0 0 0;
        padding: 8px 12px;
        border: 1px solid #999;
        border-radius: 8px;
        background-color: #f6f6f6;
    }

    .jc_drawer_row {
        margin: 6px 0;
        color: #222;
        overflow-wrap: anywhere;
    }

    @@media (max-width: 768px) {
        .jc_summary {
            flex-direction: column;
        }

        .jc_rightside {
            text-align: end;
        }
    }
</style>

@code {
    [Parameter] public DomainJob? Job { get; set; }
    [Parameter] public JobCardModel? Card { get; set; }

    private const string Placeholder = "—";

    private bool _isDrawerOpen=false;
    private DomainJob? _resolvedJob;

    private string DisplayJobName { get; set; } = Placeholder;
    private string DisplayPONumber { get; set; } = Placeholder;
    private string DisplayContacts { get; set; } = Placeholder;
    private string DisplaySiteName { get; set; } = Placeholder;
    private string DisplayAddress1 { get; set; } = string.Empty;
    private string DisplayAddress2 { get; set; } = string.Empty;
    private string DisplayDrawerContacts { get; set; } = string.Empty;
    private string DisplayPinnedNotes { get; set; } = string.Empty;
    private string DisplayScheduleDates { get; set; } = string.Empty;

    private bool HasDrawerContent =>
        !string.IsNullOrWhiteSpace(DisplayDrawerContacts) ||
        !string.IsNullOrWhiteSpace(DisplayPinnedNotes) ||
        !string.IsNullOrWhiteSpace(DisplayScheduleDates);

    private string CardCssClass => HasDrawerContent ? "jc jc_clickable" : "jc";
    private string? CardRole => HasDrawerContent ? "button" : null;
    private int? CardTabIndex => HasDrawerContent ? 0 : null;

    private DomainJob? ResolvedJob
    {
        get
        {
            if (Job is not null)
                return Job;

            _resolvedJob ??= ResolveJobFromStore();
            return _resolvedJob;
        }
    }
    protected override void OnParametersSet()
    {
        _resolvedJob = null;

        var job = ResolvedJob;

        DisplayJobName = FirstNonBlank(Card?.job_name, job?.JobName, Placeholder);
        DisplayPONumber = Card?.po_number?.ToString()
                          ?? job?.PONumber?.ToString()
                          ?? Placeholder;

        DisplayContacts = FirstNonBlank(
            Card?.primary_contacts,
            job?.GetCurrentContact()?.Name,
            Placeholder);

        DisplaySiteName = FirstNonBlank(
            Card?.site_name,
            job?.Site?.SiteName,
            Placeholder);

        DisplayAddress1 = Card?.address_1 ?? job?.Site?.Address1 ?? string.Empty;
        DisplayAddress2 = Card?.address_2 ?? job?.Site?.Address2 ?? string.Empty;

        DisplayDrawerContacts = !string.IsNullOrWhiteSpace(Card?.contacts)
            ? Card!.contacts
            : BuildAdditionalContacts(job);

        DisplayPinnedNotes = !string.IsNullOrWhiteSpace(Card?.pinned_notes)
            ? Card!.pinned_notes
            : BuildPinnedNotes(job);

        DisplayScheduleDates = !string.IsNullOrWhiteSpace(Card?.schedule_dates)
            ? Card!.schedule_dates
            : BuildScheduleDates(job);

        if (!HasDrawerContent)
        {
            _isDrawerOpen = false;
        }
    }

    private DomainJob? ResolveJobFromStore()
    {
        if (Card is null)
            return null;

        return LocalJobsStore.Jobs.FirstOrDefault(j => j.Id == Card.job_id);
    }

    private static string FirstNonBlank(params string?[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
                return value;
        }

        return string.Empty;
    }

    private static string BuildAdditionalContacts(DomainJob? job)
    {
        if (job?.Contacts is null)
            return string.Empty;

        return string.Join(", ",
            job.Contacts
               .Where(c => !c.IsPrimary &&
                           (!string.IsNullOrWhiteSpace(c.Name) || !string.IsNullOrWhiteSpace(c.Phone)))
               .Select(c => string.IsNullOrWhiteSpace(c.Phone)
                   ? c.Name
                   : $"{c.Name} ({c.Phone})"));
    }

    private static string BuildPinnedNotes(DomainJob? job)
    {
        var notes = job?.GetPinnedNotes();
        if (notes is null)
            return string.Empty;

        return string.Join(" | ",
            notes.Where(n => !string.IsNullOrWhiteSpace(n.Note))
                 .OrderByDescending(n => n.DateDtg)
                 .Select(n => n.Note));
    }

    private static string BuildScheduleDates(DomainJob? job)
    {
        if (job?.ScheduledDates is null)
            return string.Empty;

        return string.Join(", ",
            job.ScheduledDates
               .OrderBy(d => d.StartDate)
               .Select(d =>
                   d.EndDate.HasValue && d.EndDate.Value.Date > d.StartDate.Date
                       ? $"{d.StartDate:MM/dd/yyyy} - {d.EndDate.Value:MM/dd/yyyy}"
                       : $"{d.StartDate:MM/dd/yyyy}"));
    }

    private void OnCardClick()
    {
        if (!HasDrawerContent)
            return;

        _isDrawerOpen = !_isDrawerOpen;
    }

    private void HandleCardKeyDown(KeyboardEventArgs args)
    {
        if (!HasDrawerContent)
            return;

        if (args.Key is "Enter" or " ")
        {
            _isDrawerOpen = !_isDrawerOpen;
        }
    }
}