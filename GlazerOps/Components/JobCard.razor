@using GlazerOps.Models
@using MudBlazor
@using DomainJob = GlazerOps.Models.Domain.Job
@using JobCardModel = GlazerOps.Models.JobCardModel
@using Supabase
@inject Client Sb
@inject HttpClient Http
@using GlazerOps.Services
@inject LocalJobsStore LocalJobsStore

<MudPaper Class="@JobCardClass"
          Elevation="3"
          role="@CardRole"
          tabindex="@CardTabIndex"
          @onclick="ToggleDrawer"
          @onkeydown="HandleCardKeyDown">
    <div class="jc_leftside">
        <h2 class="jc_header">@_DisplayJobName</h2>
        <p class="jc_PONumber">@DisplayPONumber</p>
        <p class="jc_contacts"><strong>Contacts:</strong> @DisplayContacts</p>
    </div>
    <div class="jc_rightside">
        <p class="jc_sitename"><strong>@DisplaySiteName</strong></p>
        @if (!string.IsNullOrWhiteSpace(DisplayAddress1))
        {
            <p class="jc_location">@DisplayAddress1</p>
        }

        @if (!string.IsNullOrWhiteSpace(DisplayAddress2))
        {
            <p class="jc_location">@DisplayAddress2</p>
        }
    </div>
</MudPaper>

@if (HasDrawerContent)
{
    <MudPaper Class="jc_drawer" Elevation="1">
        <MudCollapse Expanded="_isDrawerOpen">
            <div class="jc_drawer_content">
                @if (!string.IsNullOrWhiteSpace(DisplayDrawerContacts))
                {
                    <p class="jc_drawer_row"><strong>Additional Contacts:</strong> @DisplayDrawerContacts</p>
                }

                @if (!string.IsNullOrWhiteSpace(DisplayPinnedNotes))
                {
                    <p class="jc_drawer_row"><strong>Pinned Notes:</strong> @DisplayPinnedNotes</p>
                }

                @if (!string.IsNullOrWhiteSpace(DisplayScheduleDates))
                {
                    <p class="jc_drawer_row"><strong>Schedule Dates:</strong> @DisplayScheduleDates</p>
                }
            </div>
        </MudCollapse>
    </MudPaper>
}

<style>
    .jc {
        display: flex;
        width: 100%;
        margin-bottom: 10px;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        width: 100%;
        padding: 12px;
        box-sizing: border-box;
        border-radius: 8px;
        border: 1px solid #000;
        background-color: #ddd;
    }

    .jc_clickable {
        cursor: pointer;
    }

    .jc_leftside {
        flex: 1 1 65%;
        min-width: 40%;
        text-align: left;
    }

    .jc_rightside {
        flex: 1 1 35%;
        min-width: 20%;
        text-align: right;
    }

    .jc_header {
        display: flex;
        margin: 0 0 8px 0;
        font-size: 1.25em;
        color: #c00;
        overflow-wrap: anywhere;
    }

    .jc_PONumber,
    .jc_contacts,
    .jc_sitename,
    .jc_location {
        margin: 4px 0;
        color: #111;
        overflow-wrap: anywhere;
    }

    .jc_drawer {
        margin: -6px 0 10px 0;
        padding: 8px 12px;
        border: 1px solid #999;
        border-radius: 8px;
        background-color: #f6f6f6;
    }

    .jc_drawer_content {
        margin-top: 8px;
    }

    .jc_drawer_row {
        margin: 6px 0;
        color: #222;
        overflow-wrap: anywhere;
    }

    @@media (max-width: 768px) {
        .jc {
            flex-direction: column;
        }

        .jc_rightside {
            text-align: end;
        }
    }
</style>

@code {
    [Parameter]
    public DomainJob? Job { get; set; }

    [Parameter]
    public JobCardModel? Card { get; set; }

    private bool _isDrawerOpen;

    private string JobCardClass => HasDrawerContent ? "jc jc_clickable" : "jc";

    private string? CardRole => HasDrawerContent ? "button" : null;

    private int? CardTabIndex => HasDrawerContent ? 0 : null;

    private DomainJob? ResolvedJob =>
        Job
        ?? (Card is null
            ? null
            : LocalJobsStore.Jobs.FirstOrDefault(j => j.Id == Card.job_id));

    private string _DisplayJobName =>
        !string.IsNullOrWhiteSpace(Card?.job_name) ? Card.job_name :
        !string.IsNullOrWhiteSpace(ResolvedJob?.JobName) ? ResolvedJob.JobName : "—";

    private string DisplayPONumber =>
        Card?.po_number?.ToString()
        ?? ResolvedJob?.PONumber?.ToString()
        ?? "—";

    private string DisplayContacts =>
        !string.IsNullOrWhiteSpace(Card?.primary_contacts) ? Card.primary_contacts :
        !string.IsNullOrWhiteSpace(ResolvedJob?.GetCurrentContact()?.Name) ? ResolvedJob.GetCurrentContact()!.Name : "—";

    private string DisplaySiteName =>
        !string.IsNullOrWhiteSpace(Card?.site_name) ? Card.site_name :
        !string.IsNullOrWhiteSpace(ResolvedJob?.Site?.SiteName) ? ResolvedJob.Site.SiteName : "—";

    private string DisplayAddress1 => Card?.address_1 ?? ResolvedJob?.Site?.Address1 ?? string.Empty;

    private string DisplayAddress2 => Card?.address_2 ?? ResolvedJob?.Site?.Address2 ?? string.Empty;

    private string DisplayDrawerContacts =>
        !string.IsNullOrWhiteSpace(Card?.contacts)
            ? Card.contacts
            : string.Join(", ", (ResolvedJob?.Contacts ?? Array.Empty<GlazerOps.Models.Domain.JobContact>())
                .Where(c => !c.IsPrimary)
                .Select(c => string.IsNullOrWhiteSpace(c.Phone) ? c.Name : $"{c.Name} ({c.Phone})")
                .Where(c => !string.IsNullOrWhiteSpace(c)));

    private string DisplayPinnedNotes =>
        !string.IsNullOrWhiteSpace(Card?.pinned_notes)
            ? Card.pinned_notes
            : string.Join(" | ", (ResolvedJob?.GetPinnedNotes() ?? Array.Empty<GlazerOps.Models.Domain.JobNote>())
                .Where(n => !string.IsNullOrWhiteSpace(n.Note))
                .OrderByDescending(n => n.DateDtg)
                .Select(n => n.Note));

    private string DisplayScheduleDates =>
        !string.IsNullOrWhiteSpace(Card?.schedule_dates)
            ? Card.schedule_dates
            : string.Join(", ", (ResolvedJob?.ScheduledDates ?? Array.Empty<GlazerOps.Models.Domain.JobScheduleDate>())
                .OrderBy(d => d.StartDate)
                .Select(d => d.EndDate.HasValue && d.EndDate.Value.Date > d.StartDate.Date
                    ? $"{d.StartDate:MM/dd/yyyy} - {d.EndDate.Value:MM/dd/yyyy}"
                    : $"{d.StartDate:MM/dd/yyyy}"));

    private bool HasDrawerContent =>
        !string.IsNullOrWhiteSpace(DisplayDrawerContacts)
        || !string.IsNullOrWhiteSpace(DisplayPinnedNotes)
        || !string.IsNullOrWhiteSpace(DisplayScheduleDates);

    private void ToggleDrawer()
    {
        if (!HasDrawerContent)
            return;

        _isDrawerOpen = !_isDrawerOpen;
    }

    private void HandleCardKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or " ")
        {
            ToggleDrawer();
        }
    }
}
