@using MudBlazor
@using GlazerOps.Models.Domain

<MudPaper Class="jc" Elevation="3">
    <div class="jc_leftside">
        <h2 class="jc_header">@jName</h2>
        <p class="jc_PONumber"><strong>PO:</strong> @jPO</p>
        <p class="jc_contacts"><strong>Contacts:</strong> @jContacts</p>
    </div>
    <div class="jc_rightside">
        <p class="jc_sitename"><strong>@sName</strong></p>
        <p class="jc_location">@sAddress1</p>
        <p class="jc_location">@sAddress2</p>
    </div>
</MudPaper>

<style>
    .jc {
        display: flex;
        width: 100%;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        padding: 12px;
        margin: 0 0 12px 0;
        box-sizing: border-box;
        border-radius: 8px;
        border: 1px solid #000;
        background-color: #ddd;
    }

    .jc_leftside {
        flex: 1 1 65%;
        min-width: 0;
        text-align: left;
    }

    .jc_rightside {
        flex: 1 1 35%;
        min-width: 0;
        text-align: right;
    }

    .jc_header {
        margin: 0 0 8px 0;
        font-size: 1.25em;
        color: #c00;
    }

    .jc_PONumber,
    .jc_contacts,
    .jc_sitename,
    .jc_location {
        margin: 4px 0;
        color: #111;
        overflow-wrap: anywhere;
    }
</style>

@code {
    [Parameter]
    public Job? Job { get; set; }

    private string jName => Job?.JobName ?? string.Empty;
    private string jPO => Job?.PONumber?.ToString() ?? "—";
    private string jContacts => Job?.GetCurrentContact()?.Name ?? "—";

    private string sName => string.IsNullOrWhiteSpace(Job?.Site?.SiteName) ? "—" : Job!.Site!.SiteName;
    private string sAddress1 => Job?.Site?.Address1 ?? string.Empty;
    private string sAddress2 => Job?.Site?.Address2 ?? string.Empty;
}
