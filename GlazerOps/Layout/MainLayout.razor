@inherits LayoutComponentBase
@inject Supabase.Client Sb
@inject NavigationManager Nav
@inject GlazerOps.Services.JobsCacheSyncService JobsCacheSync
@using MudBlazor

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @if (_sessionChecked || _isPublicRoute)
            {
                @Body
            }
        </article>
    </main>
</div>

@code {
    private bool _initialized;
    private bool _sessionChecked;
    private bool _isPublicRoute;

    protected override Task OnInitializedAsync()
    {
        var relativePath = Nav.ToBaseRelativePath(new Uri(Nav.Uri).GetLeftPart(UriPartial.Path));
        _isPublicRoute = relativePath == "login" || relativePath.StartsWith("auth/");
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
        {
            return;
        }

        _initialized = true;
        await InitializeSessionAsync();
    }

    private async Task InitializeSessionAsync()
    {
        try
        {
            await Sb.Auth.RetrieveSessionAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to restore session during initial layout render: {ex}");
        }

        var relativePath = Nav.ToBaseRelativePath(new Uri(Nav.Uri).GetLeftPart(UriPartial.Path));
        if (Sb.Auth.CurrentUser is null && relativePath != "login" && !relativePath.StartsWith("auth/"))
        {
            Nav.NavigateTo("login");
            return;
        }

        if (Sb.Auth.CurrentUser is not null)
        {
            await JobsCacheSync.StartAsync();
        }

        _sessionChecked = true;
        await InvokeAsync(StateHasChanged);
    }
}
