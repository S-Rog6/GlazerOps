@page "/"
@using Supabase
@inject Client Sb
@inject HttpClient Http

<PageTitle>Dashboard</PageTitle>

<h2>Dashboard</h2>

<div class="d-flex gap-2 flex-wrap mb-4">
    <a class="btn btn-primary" href="/jobs">Jobs</a>
    <a class="btn btn-primary" href="/sites">Sites</a>
    <a class="btn btn-outline-primary" href="/calendar-views">Calendar Views</a>
    <a class="btn btn-outline-primary" href="/preferences">Preferences</a>
    <a class="btn btn-outline-primary" href="/settings">Settings</a>
    <a class="btn btn-outline-primary" href="/users">Users</a>
</div>

<h3>Supabase Test</h3>
<p>@_msg</p>

<h3>Current User</h3>
@if (_user is not null)
{
    <p>Email: @_user.Email</p>
    <p>ID: @_user.Id</p>
}
else
{
    <p>No user is signed in.</p>
}

@code {
    private string _msg = "Loading...";
    private Supabase.Gotrue.User? _user;

    protected override async Task OnInitializedAsync()
    {
        await LoadSupabaseStatusAsync();
    }

    private async Task LoadSupabaseStatusAsync()
    {
        try
        {
            var req = new HttpRequestMessage(HttpMethod.Get, "https://mkcpedfhpiebdggrszrl.supabase.co/auth/v1/settings");
            req.Headers.Add("apikey", "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1rY3BlZGZocGllYmRnZ3JzenJsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE5Mjc0MzUsImV4cCI6MjA4NzUwMzQzNX0.1fJ7F1BA8d6U83JZGiiJi2yeqEXmvZjUnp619URZ5co");

            var res = await Http.SendAsync(req);
            _ = await res.Content.ReadAsStringAsync();

            _msg = $"Auth settings status: {(int)res.StatusCode} {res.ReasonPhrase}";
        }
        catch (Exception ex)
        {
            _msg = ex.ToString();
        }

        await Sb.Auth.RetrieveSessionAsync();
        _user = Sb.Auth.CurrentUser;
    }
}