@page "/"
@using GlazerOps.Components
@using GlazerOps.Models.Domain
@using GlazerOps.Services
@using Supabase
@inject Client Sb
@inject HttpClient Http
@inject LocalJobsStore LocalJobsStore

<PageTitle>Dashboard</PageTitle>

<h2>Dashboard</h2>

<div class="d-flex gap-2 flex-wrap mb-4">
    <a class="btn btn-primary" href="/jobs">Jobs</a>
    <a class="btn btn-primary" href="/sites">Sites</a>
    <a class="btn btn-outline-primary" href="/calendar-views">Calendar Views</a>
    <a class="btn btn-outline-primary" href="/preferences">Preferences</a>
    <a class="btn btn-outline-primary" href="/settings">Settings</a>
    <a class="btn btn-outline-primary" href="/users">Users</a>
</div>

<CardDisplayArea TItem="Job"
                 Title="Today"
                 JobIds="TodayJobIds"
                 IsLoading="isLoading"
                 EmptyText="No jobs found for today"
                 ShowSortOptions="false" />

<CardDisplayArea TItem="Job"
                 Title="Pinned"
                 JobIds="PinnedJobIds"
                 IsLoading="isLoading"
                 EmptyText="No pinned jobs"
                 ShowSortOptions="false" />

<h3>Supabase Test</h3>
<p>@_msg</p>

<h3>Current User</h3>
@if (_user is not null)
{
    <p>Email: @_user.Email</p>
    <p>ID: @_user.Id</p>
}
else
{
    <p>No user is signed in.</p>
}

@code {
    private string _msg = "Loading...";
    private Supabase.Gotrue.User? _user;
    private bool isLoading = true;
    private bool _initialized;

    private IEnumerable<long> TodayJobIds =>
        LocalJobsStore.Jobs
            .Where(IsScheduledForToday)
            .Select(job => job.Id);

    private IEnumerable<long> PinnedJobIds =>
        LocalJobsStore.Jobs
            .Where(job => job.GetPinnedNotes().Any())
            .Select(job => job.Id);

    protected override async Task OnInitializedAsync()
    {
        await LocalJobsStore.LoadAsync(50);
        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
        {
            return;
        }

        _initialized = true;
        await LoadSupabaseStatusAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadSupabaseStatusAsync()
    {
        try
        {
            using var timeout = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            var req = new HttpRequestMessage(HttpMethod.Get, "https://mkcpedfhpiebdggrszrl.supabase.co/auth/v1/settings");
            req.Headers.Add("apikey", "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1rY3BlZGZocGllYmRnZ3JzenJsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE5Mjc0MzUsImV4cCI6MjA4NzUwMzQzNX0.1fJ7F1BA8d6U83JZGiiJi2yeqEXmvZjUnp619URZ5co");

            var res = await Http.SendAsync(req, timeout.Token);
            _ = await res.Content.ReadAsStringAsync(timeout.Token);

            _msg = $"Auth settings status: {(int)res.StatusCode} {res.ReasonPhrase}";
        }
        catch (OperationCanceledException)
        {
            _msg = "Auth settings request timed out.";
        }
        catch (Exception ex)
        {
            _msg = ex.ToString();
        }

        try
        {
            await Sb.Auth.RetrieveSessionAsync();
            _user = Sb.Auth.CurrentUser;
        }
        catch (Exception ex)
        {
            _msg = $"{_msg} Session restore failed: {ex.Message}";
        }
    }

    private static bool IsScheduledForToday(Job job)
    {
        var today = DateTime.Today;
        return job.ScheduledDates.Any(d => d.StartDate.Date == today);
    }
}
