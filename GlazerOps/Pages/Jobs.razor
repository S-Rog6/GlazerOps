@page "/jobs"
@using Supabase
@using GlazerOps.Components
@using GlazerOps.Models.Data
@using GlazerOps.Models.Domain
@using GlazerOps.Services
@using ApiJobCard = GlazerOps.Models.JobCard
@inject Client Sb
@inject LocalJobsStore LocalJobsStore
@inject JobCardService JobCardService
@implements IDisposable

<PageTitle>Jobs</PageTitle>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Jobs</h3>
    <div class="btn-group" role="group">
        <button type="button" class="btn @(showTableView ? "btn-outline-primary" : "btn-primary")" @onclick="() => showTableView = false">
            Card View
        </button>
        <button type="button" class="btn @(showTableView ? "btn-primary" : "btn-outline-primary")" @onclick="() => showTableView = true">
            Table View
        </button>
    </div>
</div>

@if (showTableView)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>PO Number</th>
                    <th>Job Name</th>
                    <th>Site</th>
                    <th>Address</th>
                    <th>Contact</th>
                    <th>Assigned</th>
                    <th>Scheduled Date</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="7" class="text-center">Loading...</td>
                    </tr>
                }
                else if (!jobs.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center">No jobs found</td>
                    </tr>
                }
                else
                {
                    @foreach (var job in FilteredJobs)
                    {
                        <tr>
                            <td>@job.PONumber</td>
                            <td>@job.JobName</td>
                            <td>@job.Site?.SiteName</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(job.Site?.Address1))
                                {
                                    <div>@job.Site.Address1</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(job.Site?.Address2))
                                {
                                    <div>@job.Site.Address2</div>
                                }
                            </td>
                            <td>@job.GetCurrentContact()?.Name</td>
                            <td>@string.Join(", ", job.Assigned)</td>
                            <td>@job.GetPrimaryScheduleDate()?.ScheduledDate.ToString("MM/dd/yyyy")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}
else
{
    <CardDisplayArea TItem="ApiJobCard"
                     Title=""
                     Items="FilteredCardJobs"
                     IsLoading="isLoading"
                     FilterFunc="FilterCardJobs">
        <ChildContent Context="job">
            <JobCard Card="job" />
        </ChildContent>
    </CardDisplayArea>
}

@code {
    private const int MaxJobs = 20;
    private List<Job> jobs = new();
    private List<ApiJobCard> cardJobs = new();
    private bool isLoading;
    private string? errorMessage;
    private bool showTableView = false;
    private string filterText = string.Empty;
    private CancellationTokenSource? syncCancellation;

    private IEnumerable<Job> FilteredJobs =>
        jobs.Where(job => FilterJobs(job, filterText));

    private IEnumerable<ApiJobCard> FilteredCardJobs =>
        cardJobs.Where(job => FilterCardJobs(job, filterText));

    protected override async Task OnInitializedAsync()
    {
        syncCancellation = new CancellationTokenSource();

        isLoading = true;
        await LoadJobsFromLocalAsync();

        _ = Task.Run(() => MonitorAuthAndSyncAsync(syncCancellation.Token));
    }

    private async Task LoadJobsFromLocalAsync()
    {
        try
        {
            var localJobs = await LocalJobsStore.LoadAsync(MaxJobs);
            jobs = localJobs.ToList();
            cardJobs = jobs.Select(MapDomainToCard).ToList();

            var serviceCards = await JobCardService.GetJobCards();
            if (serviceCards.Any())
            {
                cardJobs = serviceCards.Take(MaxJobs).ToList();
            }

            errorMessage = null;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            jobs = new List<Job>();
            cardJobs = new List<ApiJobCard>();
            errorMessage = "Failed to load local jobs cache.";
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task MonitorAuthAndSyncAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await LoadJobsFromSupabaseAsync(showLoading: jobs.Count == 0 && cardJobs.Count == 0);
                await Task.Delay(TimeSpan.FromMinutes(2), cancellationToken);
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine(ex);
                await InvokeAsync(() =>
                {
                    errorMessage = "Failed to refresh jobs from server.";
                    StateHasChanged();
                });

                await Task.Delay(TimeSpan.FromSeconds(10), cancellationToken);
            }
        }
    }

    private async Task LoadJobsFromSupabaseAsync(bool showLoading)
    {
        if (showLoading)
        {
            await InvokeAsync(() =>
            {
                isLoading = true;
                errorMessage = null;
                StateHasChanged();
            });
        }

        try
        {
           

            var jobsResponse = await Sb.From<JobCardViewData>()
                .Select("*")
                .Limit(MaxJobs)
                .Get();

            var dataModels = jobsResponse?.Models ?? new List<JobCardViewData>();
            var mappedJobs = JobMapper.MapCardViewToDomain(dataModels)
                .Take(MaxJobs)
                .ToList();

            await LocalJobsStore.SaveAsync(mappedJobs, MaxJobs);
            var serviceCards = await JobCardService.GetJobCards();
            await InvokeAsync(() =>
            {
                jobs = mappedJobs;
                cardJobs = serviceCards.Any()
                    ? serviceCards.Take(MaxJobs).ToList()
                    : mappedJobs.Select(MapDomainToCard).ToList();
                errorMessage = null;
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            await InvokeAsync(() =>
            {
                if (!jobs.Any() && !cardJobs.Any())
                {
                    errorMessage = "Failed to load jobs.";
                }

                StateHasChanged();
            });
        }
        finally
        {
            if (showLoading)
            {
                await InvokeAsync(() =>
                {
                    isLoading = false;
                    StateHasChanged();
                });
            }
        }
    }

    private static bool FilterJobs(Job? job, string? filter)
    {
        if (job is null)
            return false;

        if (string.IsNullOrWhiteSpace(filter))
            return true;

        var search = filter.Trim();

        return Contains(job.JobName, search)
            || Contains(job.PONumber?.ToString(), search)
            || Contains(job.Site?.SiteName, search)
            || job.Assigned.Any(a => Contains(a, search))
            || Contains(job.GetCurrentContact()?.Name, search)
            || Contains(job.GetPinnedNotes().FirstOrDefault()?.Note, search);
    }

    private static bool FilterCardJobs(ApiJobCard? job, string? filter)
    {
        if (job is null)
            return false;

        if (string.IsNullOrWhiteSpace(filter))
            return true;

        var search = filter.Trim();

        return Contains(job.job_name, search)
            || Contains(job.po_number?.ToString(), search)
            || Contains(job.site_name, search)
            || Contains(job.primary_contacts, search)
            || Contains(job.all_contacts, search);
    }

    private static ApiJobCard MapDomainToCard(Job job)
    {
        return new ApiJobCard
        {
            job_id = job.Id,
            job_name = job.JobName,
            po_number = job.PONumber,
            site_id = job.SiteId,
            site_name = job.Site?.SiteName ?? string.Empty,
            address_1 = job.Site?.Address1 ?? string.Empty,
            address_2 = job.Site?.Address2 ?? string.Empty,
            primary_contacts = job.GetCurrentContact()?.Name ?? string.Empty,
            all_contacts = string.Join(", ", job.Contacts.Select(c => c.Name).Where(n => !string.IsNullOrWhiteSpace(n)))
        };
    }

    private static bool Contains(string? source, string value) =>
        !string.IsNullOrWhiteSpace(source) &&
        source.Contains(value, StringComparison.OrdinalIgnoreCase);

    public void Dispose()
    {
        if (syncCancellation is null)
        {
            return;
        }

        syncCancellation.Cancel();
        syncCancellation.Dispose();
        syncCancellation = null;
    }
}