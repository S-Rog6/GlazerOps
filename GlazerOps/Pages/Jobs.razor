@page "/jobs"
@using Supabase
@using GlazerOps.Components
@using GlazerOps.Models
@inject Client Sb

<PageTitle>Jobs</PageTitle>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<CardDisplayArea TItem="Job"
                 Title="Jobs"
                 Items="jobs"
                 IsLoading="isLoading"
                 FilterFunc="FilterJobs">
    <ChildContent Context="job">
        <JobCard Job="job" />
    </ChildContent>
</CardDisplayArea>

@code {
    private List<Job> jobs = new();
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadJobsAsync();
    }

    private async Task LoadJobsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Sb.From<Job>()
                .Select("*, site:sites(*), contacts:job_contacts(*), scheduled_dates:job_schedule_dates(*), notes:job_notes(*)")
                .Get();

            jobs = response?.Models ?? new List<Job>();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load jobs.";
            Console.Error.WriteLine(ex);
            jobs = new List<Job>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private static bool FilterJobs(Job? job, string? filter)
    {
        if (job is null)
            return false;

        if (string.IsNullOrWhiteSpace(filter))
            return true;

        var search = filter.Trim();

        return Contains(job.JobName, search)
            || Contains(job.PONumber?.ToString(), search)
            || Contains(job.Site?.SiteName, search)
            || Contains(job.Assigned, search)
            || Contains(job.Contacts?.FirstOrDefault(c => c.IsCurrent)?.Name, search)
            || Contains(job.Notes?.FirstOrDefault(n => n.Pinned)?.Note, search);
    }

    private static bool Contains(string? source, string value) =>
        !string.IsNullOrWhiteSpace(source) &&
        source.Contains(value, StringComparison.OrdinalIgnoreCase);
}