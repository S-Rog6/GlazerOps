@page "/jobs"
@using GlazerOps.Components
@using GlazerOps.Models.Data
@using GlazerOps.Models.Domain
@using GlazerOps.Services
@using Supabase
@inject LocalJobsStore LocalJobsStore
@inject Client SupabaseClient
@inject JobsCacheSyncService JobsCacheSync
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>Jobs</PageTitle>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="btn-group" role="group">
        <a class="btn btn-outline-secondary" href="/jobs/editor">Job Entry / Editor</a>
        <a class="btn btn-outline-secondary" href="/jobs/1">Job Details</a>
        <a class="btn btn-outline-secondary" href="/jobs/1/notes">Job Notes</a>
        <a class="btn btn-outline-secondary" href="/jobs/1/plans">Job Plans</a>
        <a class="btn btn-outline-secondary" href="/jobs/1/gallery">Job Gallery</a>
    </div>
</div>

<CardDisplayArea TItem="Job"
                 Title="Jobs View"
                 JobIds="FilteredJobIds"
                 IsLoading="isLoading"
                 IsRefreshing="isRefreshing"
                 OnRefresh="RefreshJobsAsync"
                 RefreshButtonText="Refresh Cards"
                 RefreshingText="Refreshing Cards..."
                 EmptyText="No jobs found"
                 TableColumnCount="6">
    <TableHeader>
        <tr>
            <th>Job Name</th>
            <th>PO Number</th>
            <th>Contacts</th>
            <th>Site Name</th>
            <th>Address 1</th>
            <th>Address 2</th>
        </tr>
    </TableHeader>
    <TableRow Context="job">
        <tr style="cursor: pointer;" @onclick="() => NavigateToJobDetails(job.Id)">
            <td>@job.JobName</td>
            <td>@job.PONumber</td>
            <td>@job.GetCurrentContact()?.Name</td>
            <td>@job.Site?.SiteName</td>
            <td>@job.Site?.Address1</td>
            <td>@job.Site?.Address2</td>
        </tr>
    </TableRow>
</CardDisplayArea>

@code {
    private const int MaxJobs = 20;
    private bool isLoading;
    private bool isRefreshing;
    private string? errorMessage;
    private string filterText = string.Empty;
    private List<JobCardViewData> supabasePreviewJobs = new();
    private List<Job> localPreviewJobs = new();

    private IEnumerable<Job> FilteredJobs =>
        LocalJobsStore.Jobs
            .OrderByDescending(job => job.Id)
            .Where(job => FilterJobs(job, filterText));

    private IEnumerable<long> FilteredJobIds =>
        FilteredJobs.Select(job => job.Id);

    protected override async Task OnInitializedAsync()
    {
        LocalJobsStore.Changed += HandleJobsChanged;
        isLoading = true;

        await LoadJobsFromLocalAsync();
        await JobsCacheSync.StartAsync();
        await JobsCacheSync.RefreshNowAsync();
        await LoadSupabasePreviewAsync();
    }

    public void Dispose()
    {
        LocalJobsStore.Changed -= HandleJobsChanged;
    }

    private void HandleJobsChanged()
    {
        localPreviewJobs = LocalJobsStore.Jobs
            .OrderByDescending(job => job.Id)
            .Take(5)
            .ToList();
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadJobsFromLocalAsync()
    {
        try
        {
            await LocalJobsStore.LoadAsync(MaxJobs);
            localPreviewJobs = LocalJobsStore.Jobs
                .OrderByDescending(job => job.Id)
                .Take(5)
                .ToList();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Failed to load local jobs cache.";
        }
    }

    private async Task LoadSupabasePreviewAsync()
    {
        try
        {
            var response = await SupabaseClient
                .From<JobCardViewData>()
                .Select("*")
                .Order("job_id", Supabase.Postgrest.Constants.Ordering.Descending)
                .Limit(5)
                .Get();

            supabasePreviewJobs = (response.Models ?? new List<JobCardViewData>())
                .OrderByDescending(job => job.JobId)
                .Take(5)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = string.IsNullOrWhiteSpace(errorMessage)
                ? "Failed to load Supabase preview rows."
                : $"{errorMessage} Failed to load Supabase preview rows.";
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshJobsAsync()
    {
        if (isLoading || isRefreshing)
            return;

        isRefreshing = true;
        errorMessage = null;

        try
        {
            await JobsCacheSync.RefreshNowAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Failed to refresh jobs from Supabase.";
        }
        finally
        {
            isRefreshing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void NavigateToJobDetails(long jobId)
    {
        if (jobId <= 0)
            return;

        NavigationManager.NavigateTo($"/jobs/{jobId}");
    }

    private static bool FilterJobs(Job? job, string? filter)
    {
        if (job is null)
            return false;

        if (string.IsNullOrWhiteSpace(filter))
            return true;

        var search = filter.Trim();

        return Contains(job.JobName, search)
            || Contains(job.PONumber?.ToString(), search)
            || Contains(job.Site?.SiteName, search)
            || job.Assigned.Any(a => Contains(a, search))
            || Contains(job.GetCurrentContact()?.Name, search)
            || Contains(job.GetPinnedNotes().FirstOrDefault()?.Note, search);
    }

    private static bool Contains(string? source, string value) =>
        !string.IsNullOrWhiteSpace(source) &&
        source.Contains(value, StringComparison.OrdinalIgnoreCase);
}