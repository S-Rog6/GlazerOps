@page "/jobs"
@using GlazerOps.Components
@using GlazerOps.Models.Data
@using GlazerOps.Models.Domain
@using GlazerOps.Services
@using Supabase
@using ApiJobCard = GlazerOps.Models.JobCardModel
@inject LocalJobsStore LocalJobsStore
@inject Client SupabaseClient
@inject JobsCacheSyncService JobsCacheSync
@implements IDisposable

<PageTitle>Jobs</PageTitle>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-4">
    <h5>Supabase (Top 5)</h5>
    <div class="table-responsive mb-3">
        <table class="table table-sm table-striped table-hover">
            <thead>
                <tr>
                    <th>PO Number</th>
                    <th>Job Name</th>
                    <th>Site</th>
                    <th>Contact</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="4" class="text-center">Loading...</td>
                    </tr>
                }
                else if (!supabasePreviewJobs.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center">No Supabase rows found</td>
                    </tr>
                }
                else
                {
                    @foreach (var job in supabasePreviewJobs)
                    {
                        <tr>
                            <td>@job.PONumber</td>
                            <td>@job.JobName</td>
                            <td>@job.SiteName</td>
                            <td>@(string.IsNullOrWhiteSpace(job.PrimaryContacts) ? job.AllContacts : job.PrimaryContacts)</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <h5>Local Cache (Top 5)</h5>
    <div class="table-responsive">
        <table class="table table-sm table-striped table-hover">
            <thead>
                <tr>
                    <th>PO Number</th>
                    <th>Job Name</th>
                    <th>Site</th>
                    <th>Contact</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="4" class="text-center">Loading...</td>
                    </tr>
                }
                else if (!localPreviewJobs.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center">No local rows found</td>
                    </tr>
                }
                else
                {
                    @foreach (var job in localPreviewJobs)
                    {
                        <tr>
                            <td>@job.PONumber</td>
                            <td>@job.JobName</td>
                            <td>@job.Site?.SiteName</td>
                            <td>@job.GetCurrentContact()?.Name</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Jobs</h3>
    <div class="btn-group" role="group">
        <button type="button" class="btn @(showTableView ? "btn-outline-primary" : "btn-primary")" @onclick="() => showTableView = false">
            Card View
        </button>
        <button type="button" class="btn @(showTableView ? "btn-primary" : "btn-outline-primary")" @onclick="() => showTableView = true">
            Table View
        </button>
    </div>
</div>

@if (showTableView)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>PO Number</th>
                    <th>Job Name</th>
                    <th>Site</th>
                    <th>Address</th>
                    <th>Contact</th>
                    <th>Assigned</th>
                    <th>Scheduled Date</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="7" class="text-center">Loading...</td>
                    </tr>
                }
                else if (!LocalJobsStore.Jobs.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center">No jobs found</td>
                    </tr>
                }
                else
                {
                    @foreach (var job in FilteredJobs)
                    {
                        <tr>
                            <td>@job.PONumber</td>
                            <td>@job.JobName</td>
                            <td>@job.Site?.SiteName</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(job.Site?.Address1))
                                {
                                    <div>@job.Site.Address1</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(job.Site?.Address2))
                                {
                                    <div>@job.Site.Address2</div>
                                }
                            </td>
                            <td>@job.GetCurrentContact()?.Name</td>
                            <td>@string.Join(", ", job.Assigned)</td>
                            <td>@job.GetPrimaryScheduleDate()?.StartDate.ToString("MM/dd/yyyy")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}
else
{
    <CardDisplayArea TItem="ApiJobCard"
                     Title=""
                     Items="FilteredCardJobs"
                     IsLoading="isLoading"
                     FilterFunc="FilterCardJobs">
        <ChildContent Context="job">
            <JobCard Card="job" />
        </ChildContent>
    </CardDisplayArea>
}

@code {
    private const int MaxJobs = 20;
    private bool isLoading;
    private string? errorMessage;
    private bool showTableView = false;
    private string filterText = string.Empty;
    private List<JobCardViewData> supabasePreviewJobs = new();
    private List<Job> localPreviewJobs = new();

    private IEnumerable<Job> FilteredJobs =>
        LocalJobsStore.Jobs.Where(job => FilterJobs(job, filterText));

    private IEnumerable<ApiJobCard> FilteredCardJobs =>
        LocalJobsStore.Jobs
            .Select(MapDomainToCard)
            .Where(job => FilterCardJobs(job, filterText));

    protected override async Task OnInitializedAsync()
    {
        LocalJobsStore.Changed += HandleJobsChanged;
        isLoading = true;

        await LoadJobsFromLocalAsync();
        await JobsCacheSync.StartAsync();
        await JobsCacheSync.RefreshNowAsync();
        await LoadSupabasePreviewAsync();
    }

    public void Dispose()
    {
        LocalJobsStore.Changed -= HandleJobsChanged;
    }

    private void HandleJobsChanged()
    {
        localPreviewJobs = LocalJobsStore.Jobs.Take(5).ToList();
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadJobsFromLocalAsync()
    {
        try
        {
            await LocalJobsStore.LoadAsync(MaxJobs);
            localPreviewJobs = LocalJobsStore.Jobs.Take(5).ToList();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "Failed to load local jobs cache.";
        }
    }

    private async Task LoadSupabasePreviewAsync()
    {
        try
        {
            var response = await SupabaseClient
                .From<JobCardViewData>()
                .Select("*")
                .Limit(5)
                .Get();

            supabasePreviewJobs = (response.Models ?? new List<JobCardViewData>())
                .Take(5)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = string.IsNullOrWhiteSpace(errorMessage)
                ? "Failed to load Supabase preview rows."
                : $"{errorMessage} Failed to load Supabase preview rows.";
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool FilterJobs(Job? job, string? filter)
    {
        if (job is null)
            return false;

        if (string.IsNullOrWhiteSpace(filter))
            return true;

        var search = filter.Trim();

        return Contains(job.JobName, search)
            || Contains(job.PONumber?.ToString(), search)
            || Contains(job.Site?.SiteName, search)
            || job.Assigned.Any(a => Contains(a, search))
            || Contains(job.GetCurrentContact()?.Name, search)
            || Contains(job.GetPinnedNotes().FirstOrDefault()?.Note, search);
    }

    private static bool FilterCardJobs(ApiJobCard? job, string? filter)
    {
        if (job is null)
            return false;

        if (string.IsNullOrWhiteSpace(filter))
            return true;

        var search = filter.Trim();

        return Contains(job.job_name, search)
            || Contains(job.po_number?.ToString(), search)
            || Contains(job.site_name, search)
            || Contains(job.primary_contacts, search)
            || Contains(job.all_contacts, search);
    }

    private static ApiJobCard MapDomainToCard(Job job)
    {
        return new ApiJobCard
        {
            job_id = job.Id,
            job_name = job.JobName,
            po_number = job.PONumber,
            site_id = job.SiteId,
            site_name = job.Site?.SiteName ?? string.Empty,
            address_1 = job.Site?.Address1 ?? string.Empty,
            address_2 = job.Site?.Address2 ?? string.Empty,
            primary_contacts = job.GetCurrentContact()?.Name ?? string.Empty,
            all_contacts = string.Join(", ", job.Contacts.Select(c => c.Name).Where(n => !string.IsNullOrWhiteSpace(n)))
        };
    }

    private static bool Contains(string? source, string value) =>
        !string.IsNullOrWhiteSpace(source) &&
        source.Contains(value, StringComparison.OrdinalIgnoreCase);
}